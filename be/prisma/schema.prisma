generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tenant")
}

model Staff {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  passwordHash  String?
  bitrixId      String?
  googleId      String?  @unique
  microsoftId   String?  @unique
  active        Boolean  @default(true)
  tenantId      String   @default("ventas")
  roleId        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  role              Role?      @relation(fields: [roleId], references: [id])
  createdProcedures Procedure[] @relation("ProcedureCreatedBy")
  updatedProcedures Procedure[] @relation("ProcedureUpdatedBy")
  createdHets       Het[]       @relation("HetCreatedBy")
  updatedHets       Het[]       @relation("HetUpdatedBy")
  createdPhases     Phase[]     @relation("PhaseCreatedBy")
  updatedPhases     Phase[]     @relation("PhaseUpdatedBy")
  createdWorkOrders WorkOrder[] @relation("WorkOrderCreatedBy")
  updatedWorkOrders WorkOrder[] @relation("WorkOrderUpdatedBy")
  createdBoms        Bom[]        @relation("BomCreatedBy")
  updatedBoms        Bom[]        @relation("BomUpdatedBy")
  createdBomLines    BomLine[]    @relation("BomLineCreatedBy")
  updatedBomLines    BomLine[]    @relation("BomLineUpdatedBy")
  createdWoSerials   WoSerial[]   @relation("WoSerialCreatedBy")
  updatedWoSerials   WoSerial[]   @relation("WoSerialUpdatedBy")
  createdSterilises  Sterilise[]  @relation("SteriliseCreatedBy")
  updatedSterilises  Sterilise[]  @relation("SteriliseUpdatedBy")
  createdPhaseEquips PhaseEquip[] @relation("PhaseEquipCreatedBy")
  updatedPhaseEquips PhaseEquip[] @relation("PhaseEquipUpdatedBy")
  startedWorkOrders  WorkOrder[]  @relation("WorkOrderStartSignBy")
  endedWorkOrders    WorkOrder[]  @relation("WorkOrderEndSignBy")
  signedSterilises   Sterilise[]  @relation("SteriliseSignBy")
  createdManufacturers Manufacturer[] @relation("ManufacturerCreatedBy")
  updatedManufacturers Manufacturer[] @relation("ManufacturerUpdatedBy")
  createdWorkflows     Workflow[]   @relation("WorkflowCreatedBy")
  updatedWorkflows     Workflow[]   @relation("WorkflowUpdatedBy")

  @@index([tenantId])
  @@map("staff")
}

model Role {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  builtIn     Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  staff Staff[]

  @@map("role")
}

model Manufacturer {
  id            String    @id @default(cuid())
  tenantId      String    @default("ventas")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdById   String?
  updatedById   String?
  manuName      String?
  manuNumber    String?
  keyText       String?

  createdBy     Staff?       @relation("ManufacturerCreatedBy", fields: [createdById], references: [id])
  updatedBy     Staff?       @relation("ManufacturerUpdatedBy", fields: [updatedById], references: [id])
  workOrders    WorkOrder[]
  sterilises    Sterilise[]
  batchHets     ManufacturerHet[]

  @@index([tenantId])
  @@map("manufacturer")
}

model Procedure {
  id             String      @id
  tenantId       String      @default("ventas")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  createdById    String?
  updatedById    String?
  procedureName  String?
  procedureDesc  String?
  procedureShort String?
  keyText        String?

  createdBy      Staff?           @relation("ProcedureCreatedBy", fields: [createdById], references: [id])
  updatedBy      Staff?           @relation("ProcedureUpdatedBy", fields: [updatedById], references: [id])
  phases         PhaseProcedure[]

  @@index([tenantId])
  @@map("procedure")
}

model Bom {
  id          String    @id
  tenantId    String    @default("ventas")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?
  updatedById String?
  bomName     String?
  keyText     String?

  createdBy   Staff?     @relation("BomCreatedBy", fields: [createdById], references: [id])
  updatedBy   Staff?     @relation("BomUpdatedBy", fields: [updatedById], references: [id])
  lines       BomLine[]
  phases      Phase[]

  @@index([tenantId])
  @@map("bom")
}

model BomLine {
  id          String     @id
  tenantId    String     @default("ventas")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  createdById String?
  updatedById String?
  bomId       String
  bomName     String?
  description String?
  quantity    Decimal?   @db.Decimal(18, 4)
  uom         String?
  hasSerial   Boolean   @default(false)
  deleted     Boolean   @default(false)
  keyText     String?

  createdBy   Staff?      @relation("BomLineCreatedBy", fields: [createdById], references: [id])
  updatedBy   Staff?      @relation("BomLineUpdatedBy", fields: [updatedById], references: [id])
  bom         Bom         @relation(fields: [bomId], references: [id])
  woSerials   WoSerial[]

  @@index([tenantId])
  @@map("bomLine")
}

model Het {
  id                 String            @id
  tenantId           String            @default("ventas")
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  createdById        String?
  updatedById        String?
  clinicId           String?
  HCICode            String?
  clinicName         String?
  licenseName        String?
  address            String?
  hetNumber          String?
  parcelTrackingNumber String?
  deliverId          String?
  collectId          String?
  usedById           String?
  finishedById       String?
  quantity           Int?
  deleted            Boolean           @default(false)
  forceField         Int?
  keyText            String?
  b11Weight          Decimal?          @db.Decimal(18, 4)
  collectionUnitId   String?
  collectionReceiptLineId String?
  sourceSystem       String?
  legacyClinicId     String?
  legacyDeliverId    String?
  legacyCollectId    String?

  createdBy          Staff?            @relation("HetCreatedBy", fields: [createdById], references: [id])
  updatedBy          Staff?            @relation("HetUpdatedBy", fields: [updatedById], references: [id])
  usedBy             WorkOrder?        @relation("HetUsedBy", fields: [usedById], references: [id])
  finishedBy         WorkOrder?        @relation("HetFinishedBy", fields: [finishedById], references: [id])
  workOrders         WorkOrder[]       @relation("WorkOrderHet")
  workOrderHets      WorkOrderHet[]
  steriliseHets      SteriliseHet[]
  manufacturerHets   ManufacturerHet[]

  @@index([tenantId])
  @@index([collectionUnitId])
  @@index([collectionReceiptLineId])
  @@map("het")
}

model Workflow {
  id          String   @id @default(cuid())
  tenantId    String   @default("ventas")
  name        String
  code        String
  description String?
  active      Boolean  @default(true)
  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   Staff?          @relation("WorkflowCreatedBy", fields: [createdById], references: [id])
  updatedBy   Staff?          @relation("WorkflowUpdatedBy", fields: [updatedById], references: [id])
  phases      WorkflowPhase[]
  workOrders  WorkOrder[]

  @@index([tenantId])
  @@unique([tenantId, code])
  @@map("workflow")
}

model WorkflowPhase {
  workflowId String
  phaseId    String
  sortOrder  Int

  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  phase      Phase    @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  @@id([workflowId, phaseId])
  @@unique([workflowId, sortOrder])
  @@map("workflowPhase")
}

model Phase {
  id             String             @id
  tenantId       String             @default("ventas")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  createdById    String?
  updatedById    String?
  phaseName      String?
  phaseShort     String?
  phaseOrder     Int?
  description    String?
  bomId          String?
  keyText        String?

  createdBy      Staff?             @relation("PhaseCreatedBy", fields: [createdById], references: [id])
  updatedBy      Staff?             @relation("PhaseUpdatedBy", fields: [updatedById], references: [id])
  bom            Bom?               @relation(fields: [bomId], references: [id])
  procedures     PhaseProcedure[]
  phaseEquips    PhasePhaseEquip[]
  workflows      WorkflowPhase[]
  currentWorkOrders WorkOrder[]      @relation("WorkOrderCurrentPhase")
  nextWorkOrders WorkOrder[]         @relation("WorkOrderNextPhase")

  @@index([tenantId])
  @@map("phase")
}

model PhaseProcedure {
  phaseId     String
  procedureId String
  phase       Phase     @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  procedure   Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)

  @@id([phaseId, procedureId])
  @@map("phaseProcedure")
}

model PhaseEquip {
  id          String            @id
  tenantId    String            @default("ventas")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  createdById String?
  updatedById String?
  equipId     String?
  name        String?
  description String?
  keyText     String?

  createdBy   Staff?            @relation("PhaseEquipCreatedBy", fields: [createdById], references: [id])
  updatedBy   Staff?            @relation("PhaseEquipUpdatedBy", fields: [updatedById], references: [id])
  phases      PhasePhaseEquip[]
  workOrders  WorkOrderPhaseEquip[]

  @@index([tenantId])
  @@map("phaseEquip")
}

model PhasePhaseEquip {
  phaseId      String
  phaseEquipId String
  phase        Phase      @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  phaseEquip   PhaseEquip @relation(fields: [phaseEquipId], references: [id], onDelete: Cascade)

  @@id([phaseId, phaseEquipId])
  @@map("phasePhaseEquip")
}

model WorkOrder {
  id                     String                @id
  tenantId               String                @default("ventas")
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  createdById            String?
  updatedById            String?
  hetId                  String?
  phaseId                String?
  phaseOrder             Int?
  phaseShort             String?
  prodStart              DateTime?
  startSignPath          String?
  startSignById          String?
  prodEnd                DateTime?
  endSignPath            String?
  endSignById            String?
  prodDuration           Decimal?              @db.Decimal(18, 4)
  manuId                 String?
  manuNumber             String?
  woNumber               String?
  reportPdfPath          String?
  deleted                Boolean               @default(false)
  forceField             Int?
  keyText                String?
  previousWoId           String?
  steralisationCurrentId String?               @unique
  nextPhaseId            String?
  workflowId             String?

  createdBy              Staff?                @relation("WorkOrderCreatedBy", fields: [createdById], references: [id])
  updatedBy              Staff?                @relation("WorkOrderUpdatedBy", fields: [updatedById], references: [id])
  het                    Het?                  @relation("WorkOrderHet", fields: [hetId], references: [id])
  phase                  Phase?                @relation("WorkOrderCurrentPhase", fields: [phaseId], references: [id])
  startSignBy            Staff?                @relation("WorkOrderStartSignBy", fields: [startSignById], references: [id])
  endSignBy              Staff?                @relation("WorkOrderEndSignBy", fields: [endSignById], references: [id])
  manufacturer           Manufacturer?         @relation(fields: [manuId], references: [id])
  previousWo             WorkOrder?            @relation("WorkOrderPrevious", fields: [previousWoId], references: [id])
  nextWorkOrders         WorkOrder[]           @relation("WorkOrderPrevious")
  steralisationCurrent   Sterilise?            @relation("WorkOrderSterilisationCurrent", fields: [steralisationCurrentId], references: [id])
  nextPhase              Phase?                @relation("WorkOrderNextPhase", fields: [nextPhaseId], references: [id])
  workflow               Workflow?             @relation(fields: [workflowId], references: [id])
  woSerials              WoSerial[]
  sterilises             Sterilise[]
  batchHets              WorkOrderHet[]
  phaseEquips            WorkOrderPhaseEquip[]
  usedHets               Het[]                 @relation("HetUsedBy")
  finishedHets           Het[]                 @relation("HetFinishedBy")

  @@index([workflowId])
  @@index([tenantId])
  @@map("workOrder")
}

model WorkOrderHet {
  workOrderId String
  hetId       String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  het         Het       @relation(fields: [hetId], references: [id], onDelete: Cascade)

  @@id([workOrderId, hetId])
  @@map("workOrderHet")
}

model WorkOrderPhaseEquip {
  workOrderId  String
  phaseEquipId String
  workOrder    WorkOrder  @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  phaseEquip   PhaseEquip @relation(fields: [phaseEquipId], references: [id], onDelete: Cascade)

  @@id([workOrderId, phaseEquipId])
  @@map("workOrderPhaseEquip")
}

model WoSerial {
  id          String     @id
  tenantId    String     @default("ventas")
  createdOn   DateTime   @default(now())
  createdById String?
  updatedOn   DateTime   @updatedAt
  updatedById String?
  workOrderId String
  bomRefId    String
  serialNumber String?
  keyText     String?

  createdBy   Staff?     @relation("WoSerialCreatedBy", fields: [createdById], references: [id])
  updatedBy   Staff?     @relation("WoSerialUpdatedBy", fields: [updatedById], references: [id])
  workOrder   WorkOrder  @relation(fields: [workOrderId], references: [id])
  bomRef      BomLine    @relation(fields: [bomRefId], references: [id])

  @@index([tenantId])
  @@map("woSerial")
}

model Sterilise {
  id          String         @id
  tenantId    String         @default("ventas")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  createdById String?
  workOrderId String
  manuId      String?
  direction   String?
  result      Boolean?
  betReading  Decimal?       @db.Decimal(18, 4)
  quantity    Int?
  comment     String?
  imagePath   String?
  signOn      DateTime?
  signById    String?
  signaturePath String?
  keyText     String?

  createdBy   Staff?         @relation("SteriliseCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   Staff?         @relation("SteriliseUpdatedBy", fields: [updatedById], references: [id])
  workOrder   WorkOrder      @relation(fields: [workOrderId], references: [id])
  manufacturer Manufacturer? @relation(fields: [manuId], references: [id])
  signBy      Staff?         @relation("SteriliseSignBy", fields: [signById], references: [id])
  batchHets   SteriliseHet[]
  currentWorkOrder WorkOrder?  @relation("WorkOrderSterilisationCurrent")

  @@index([tenantId])
  @@map("sterilise")
}

model SteriliseHet {
  steriliseId String
  hetId       String
  sterilise   Sterilise @relation(fields: [steriliseId], references: [id], onDelete: Cascade)
  het         Het       @relation(fields: [hetId], references: [id], onDelete: Cascade)

  @@id([steriliseId, hetId])
  @@map("steriliseHet")
}

model ManufacturerHet {
  manufacturerId String
  hetId          String
  manufacturer   Manufacturer @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)
  het            Het          @relation(fields: [hetId], references: [id], onDelete: Cascade)

  @@id([manufacturerId, hetId])
  @@map("manufacturerHet")
}

model SupplyEntity {
  id             String   @id
  tenantId       String
  name           String?
  legalName      String?
  externalCode   String?
  sourceSystem   String?
  legacyGroupKey String?
  legacyClinicId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
  @@index([legacyClinicId])
  @@map("supplyEntity")
}

model CollectionPoint {
  id             String   @id
  tenantId       String
  supplyEntityId String
  legacyClinicId String?
  hciCode        String?
  displayName    String?
  licenseName    String?
  address        String?
  postalCode     String?
  telephone      String?
  personInCharge String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
  @@index([supplyEntityId])
  @@index([legacyClinicId])
  @@map("collectionPoint")
}

model CollectionUnit {
  id                      String   @id
  tenantId                String
  supplyEntityId          String?
  collectionPointId       String?
  legacyHetId             String?
  unitNumber              String?
  parcelTrackingNumber    String?
  status                  String
  legacyDeliverId         String?
  legacyCollectId         String?
  legacyUsedByWorkOrderId String?
  legacyNextHetId         String?
  sourceSystem            String?
  linkCompleteness        String?
  semanticConfidence      String?
  hiddenFromOperations    Boolean  @default(false)
  deleted                 Boolean  @default(false)
  legacyRaw               Json?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([tenantId])
  @@index([legacyHetId])
  @@index([collectionPointId])
  @@index([legacyUsedByWorkOrderId])
  @@index([status])
  @@map("collectionUnit")
}

model IssuanceOrder {
  id                     String   @id
  tenantId               String
  supplyEntityId         String?
  collectionPointId      String?
  issuedAt               DateTime?
  issuedBy               String?
  legacyDeliverCollectId String?
  legacyDirection        String?
  semanticConfidence     String?
  level                  String?
  remarks                String?
  legacyRaw              Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([tenantId])
  @@index([collectionPointId])
  @@index([legacyDeliverCollectId])
  @@map("issuanceOrder")
}

model IssuanceOrderLine {
  id                   String   @id @default(cuid())
  tenantId             String
  issuanceOrderId      String
  collectionUnitId     String?
  legacyHetId          String?
  legacyHetNumber      String?
  parcelTrackingNumber String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([issuanceOrderId, legacyHetId])
  @@index([tenantId])
  @@index([collectionUnitId])
  @@map("issuanceOrderLine")
}

model CollectionUnitFulfilment {
  id               String   @id @default(cuid())
  tenantId         String
  collectionUnitId String
  fulfilledAt      DateTime?
  fulfilledBy      String?
  source           String?
  evidencePath     String?
  remarks          String?
  inferred         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([collectionUnitId, source])
  @@index([tenantId])
  @@map("collectionUnitFulfilment")
}

model CollectionOrder {
  id                            String   @id
  tenantId                      String
  supplyEntityId                String?
  collectionPointId             String?
  requestedAt                   DateTime?
  scheduledFor                  DateTime?
  requestedBy                   String?
  status                        String
  legacyCollectDeliverCollectId String?
  legacyDirection               String?
  semanticConfidence            String?
  legacyConflatedOrderReceipt   Boolean  @default(false)
  level                         String?
  remarks                       String?
  legacyRaw                     Json?
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  @@index([tenantId])
  @@index([collectionPointId])
  @@index([legacyCollectDeliverCollectId])
  @@map("collectionOrder")
}

model CollectionReceipt {
  id                            String   @id
  tenantId                      String
  collectionOrderId             String?
  receivedAt                    DateTime?
  receivedBy                    String?
  signaturePath                 String?
  remarks                       String?
  legacyCollectDeliverCollectId String?
  legacyConflatedOrderReceipt   Boolean  @default(false)
  acceptanceState               String?
  legacyRaw                     Json?
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  @@index([tenantId])
  @@index([collectionOrderId])
  @@index([legacyCollectDeliverCollectId])
  @@map("collectionReceipt")
}

model CollectionReceiptLine {
  id                  String   @id @default(cuid())
  tenantId            String
  collectionReceiptId String
  collectionUnitId    String?
  conditionStatus     String?
  acceptanceStatus    String?
  resultingHetId      String?
  discrepancyReason   String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([collectionReceiptId, collectionUnitId])
  @@index([tenantId])
  @@index([collectionUnitId])
  @@index([resultingHetId])
  @@map("collectionReceiptLine")
}

model ProcurementImportReport {
  id         String   @id @default(cuid())
  tenantId   String
  source     String
  dryRun     Boolean  @default(false)
  startedAt  DateTime @default(now())
  finishedAt DateTime?
  report     Json

  @@index([tenantId])
  @@map("procurementImportReport")
}

model PrintLabel {
  id             String   @id @default(cuid())
  tenantId       String   @default("ventas")
  path           String?
  fileUrl        String?
  createdTime    DateTime?
  lastModifiedBy String?
  mimeType       String?

  @@index([tenantId])
  @@map("printLabel")
}
