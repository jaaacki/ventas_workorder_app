generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tenant")
}

model Staff {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  bitrixId     String?
  googleId     String?  @unique
  microsoftId  String?  @unique
  active       Boolean  @default(true)
  tenantId     String   @default("ventas")
  roleId       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  role                 Role?          @relation(fields: [roleId], references: [id])
  createdProcedures    Procedure[]    @relation("ProcedureCreatedBy")
  updatedProcedures    Procedure[]    @relation("ProcedureUpdatedBy")
  createdHets          Het[]          @relation("HetCreatedBy")
  updatedHets          Het[]          @relation("HetUpdatedBy")
  createdPhases        Phase[]        @relation("PhaseCreatedBy")
  updatedPhases        Phase[]        @relation("PhaseUpdatedBy")
  createdWorkOrders    WorkOrder[]    @relation("WorkOrderCreatedBy")
  updatedWorkOrders    WorkOrder[]    @relation("WorkOrderUpdatedBy")
  createdBoms          Bom[]          @relation("BomCreatedBy")
  updatedBoms          Bom[]          @relation("BomUpdatedBy")
  createdBomLines      BomLine[]      @relation("BomLineCreatedBy")
  updatedBomLines      BomLine[]      @relation("BomLineUpdatedBy")
  createdWoSerials     WoSerial[]     @relation("WoSerialCreatedBy")
  updatedWoSerials     WoSerial[]     @relation("WoSerialUpdatedBy")
  createdSterilises    Sterilise[]    @relation("SteriliseCreatedBy")
  updatedSterilises    Sterilise[]    @relation("SteriliseUpdatedBy")
  createdPhaseEquips   PhaseEquip[]   @relation("PhaseEquipCreatedBy")
  updatedPhaseEquips   PhaseEquip[]   @relation("PhaseEquipUpdatedBy")
  startedWorkOrders    WorkOrder[]    @relation("WorkOrderStartSignBy")
  endedWorkOrders      WorkOrder[]    @relation("WorkOrderEndSignBy")
  signedSterilises     Sterilise[]    @relation("SteriliseSignBy")
  createdManufacturers Manufacturer[] @relation("ManufacturerCreatedBy")
  updatedManufacturers Manufacturer[] @relation("ManufacturerUpdatedBy")
  createdWorkflows     Workflow[]     @relation("WorkflowCreatedBy")
  updatedWorkflows     Workflow[]     @relation("WorkflowUpdatedBy")

  @@index([tenantId])
  @@map("staff")
}

model Role {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  builtIn     Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  staff Staff[]

  @@map("role")
}

model Manufacturer {
  id          String   @id @default(cuid())
  tenantId    String   @default("ventas")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  manuName    String?
  manuNumber  String?
  keyText     String?

  createdBy  Staff?            @relation("ManufacturerCreatedBy", fields: [createdById], references: [id])
  updatedBy  Staff?            @relation("ManufacturerUpdatedBy", fields: [updatedById], references: [id])
  workOrders WorkOrder[]
  sterilises Sterilise[]
  batchHets  ManufacturerHet[]

  @@index([tenantId])
  @@map("manufacturer")
}

model Procedure {
  id             String   @id
  tenantId       String   @default("ventas")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  procedureName  String?
  procedureDesc  String?
  procedureShort String?
  keyText        String?

  createdBy Staff?           @relation("ProcedureCreatedBy", fields: [createdById], references: [id])
  updatedBy Staff?           @relation("ProcedureUpdatedBy", fields: [updatedById], references: [id])
  phases    PhaseProcedure[]

  @@index([tenantId])
  @@map("procedure")
}

model Bom {
  id          String   @id
  tenantId    String   @default("ventas")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  bomName     String?
  keyText     String?

  createdBy Staff?    @relation("BomCreatedBy", fields: [createdById], references: [id])
  updatedBy Staff?    @relation("BomUpdatedBy", fields: [updatedById], references: [id])
  lines     BomLine[]
  phases    Phase[]

  @@index([tenantId])
  @@map("bom")
}

model BomLine {
  id          String   @id
  tenantId    String   @default("ventas")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  bomId       String
  bomName     String?
  description String?
  quantity    Decimal? @db.Decimal(18, 4)
  uom         String?
  hasSerial   Boolean  @default(false)
  deleted     Boolean  @default(false)
  keyText     String?

  createdBy Staff?     @relation("BomLineCreatedBy", fields: [createdById], references: [id])
  updatedBy Staff?     @relation("BomLineUpdatedBy", fields: [updatedById], references: [id])
  bom       Bom        @relation(fields: [bomId], references: [id])
  woSerials WoSerial[]

  @@index([tenantId])
  @@map("bomLine")
}

model Het {
  id                      String                 @id
  tenantId                String                 @default("ventas")
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  createdById             String?
  updatedById             String?
  clinicId                String?
  HCICode                 String?
  clinicName              String?
  licenseName             String?
  address                 String?
  hetNumber               String?
  parcelTrackingNumber    String?
  deliverId               String?
  collectId               String?
  usedById                String?
  finishedById            String?
  quantity                Int?
  deleted                 Boolean                @default(false)
  forceField              Int?
  keyText                 String?
  b11Weight               Decimal?               @db.Decimal(18, 4)
  collectionUnitId        String?
  collectionReceiptLineId String?
  collectionUnit          CollectionUnit?        @relation(fields: [collectionUnitId], references: [id])
  collectionReceiptLine   CollectionReceiptLine? @relation(fields: [collectionReceiptLineId], references: [id])
  inventoryLot            InventoryLot?          @relation("HetInventoryLot")
  sourceSystem            String?
  legacyClinicId          String?
  legacyDeliverId         String?
  legacyCollectId         String?

  createdBy        Staff?            @relation("HetCreatedBy", fields: [createdById], references: [id])
  updatedBy        Staff?            @relation("HetUpdatedBy", fields: [updatedById], references: [id])
  usedBy           WorkOrder?        @relation("HetUsedBy", fields: [usedById], references: [id])
  finishedBy       WorkOrder?        @relation("HetFinishedBy", fields: [finishedById], references: [id])
  workOrders       WorkOrder[]       @relation("WorkOrderHet")
  workOrderHets    WorkOrderHet[]
  steriliseHets    SteriliseHet[]
  manufacturerHets ManufacturerHet[]

  @@index([tenantId])
  @@index([collectionUnitId])
  @@index([collectionReceiptLineId])
  @@map("het")
}

model Workflow {
  id          String   @id @default(cuid())
  tenantId    String   @default("ventas")
  name        String
  code        String
  description String?
  active      Boolean  @default(true)
  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy  Staff?          @relation("WorkflowCreatedBy", fields: [createdById], references: [id])
  updatedBy  Staff?          @relation("WorkflowUpdatedBy", fields: [updatedById], references: [id])
  phases     WorkflowPhase[]
  workOrders WorkOrder[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("workflow")
}

model WorkflowPhase {
  workflowId String
  phaseId    String
  sortOrder  Int

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  phase    Phase    @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  @@id([workflowId, phaseId])
  @@unique([workflowId, sortOrder])
  @@map("workflowPhase")
}

model Phase {
  id          String   @id
  tenantId    String   @default("ventas")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  phaseName   String?
  phaseShort  String?
  phaseOrder  Int?
  description String?
  bomId       String?
  keyText     String?

  createdBy         Staff?            @relation("PhaseCreatedBy", fields: [createdById], references: [id])
  updatedBy         Staff?            @relation("PhaseUpdatedBy", fields: [updatedById], references: [id])
  bom               Bom?              @relation(fields: [bomId], references: [id])
  procedures        PhaseProcedure[]
  phaseEquips       PhasePhaseEquip[]
  workflows         WorkflowPhase[]
  currentWorkOrders WorkOrder[]       @relation("WorkOrderCurrentPhase")
  nextWorkOrders    WorkOrder[]       @relation("WorkOrderNextPhase")

  @@index([tenantId])
  @@map("phase")
}

model PhaseProcedure {
  phaseId     String
  procedureId String
  phase       Phase     @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  procedure   Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)

  @@id([phaseId, procedureId])
  @@map("phaseProcedure")
}

model PhaseEquip {
  id          String   @id
  tenantId    String   @default("ventas")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  equipId     String?
  name        String?
  description String?
  keyText     String?

  createdBy  Staff?                @relation("PhaseEquipCreatedBy", fields: [createdById], references: [id])
  updatedBy  Staff?                @relation("PhaseEquipUpdatedBy", fields: [updatedById], references: [id])
  phases     PhasePhaseEquip[]
  workOrders WorkOrderPhaseEquip[]

  @@index([tenantId])
  @@map("phaseEquip")
}

model PhasePhaseEquip {
  phaseId      String
  phaseEquipId String
  phase        Phase      @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  phaseEquip   PhaseEquip @relation(fields: [phaseEquipId], references: [id], onDelete: Cascade)

  @@id([phaseId, phaseEquipId])
  @@map("phasePhaseEquip")
}

model WorkOrder {
  id                     String    @id
  tenantId               String    @default("ventas")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  createdById            String?
  updatedById            String?
  hetId                  String?
  phaseId                String?
  phaseOrder             Int?
  phaseShort             String?
  prodStart              DateTime?
  startSignPath          String?
  startSignById          String?
  prodEnd                DateTime?
  endSignPath            String?
  endSignById            String?
  prodDuration           Decimal?  @db.Decimal(18, 4)
  manuId                 String?
  manuNumber             String?
  woNumber               String?
  reportPdfPath          String?
  deleted                Boolean   @default(false)
  forceField             Int?
  keyText                String?
  previousWoId           String?
  steralisationCurrentId String?   @unique
  nextPhaseId            String?
  workflowId             String?

  createdBy             Staff?                          @relation("WorkOrderCreatedBy", fields: [createdById], references: [id])
  updatedBy             Staff?                          @relation("WorkOrderUpdatedBy", fields: [updatedById], references: [id])
  het                   Het?                            @relation("WorkOrderHet", fields: [hetId], references: [id])
  phase                 Phase?                          @relation("WorkOrderCurrentPhase", fields: [phaseId], references: [id])
  startSignBy           Staff?                          @relation("WorkOrderStartSignBy", fields: [startSignById], references: [id])
  endSignBy             Staff?                          @relation("WorkOrderEndSignBy", fields: [endSignById], references: [id])
  manufacturer          Manufacturer?                   @relation(fields: [manuId], references: [id])
  previousWo            WorkOrder?                      @relation("WorkOrderPrevious", fields: [previousWoId], references: [id])
  nextWorkOrders        WorkOrder[]                     @relation("WorkOrderPrevious")
  steralisationCurrent  Sterilise?                      @relation("WorkOrderSterilisationCurrent", fields: [steralisationCurrentId], references: [id])
  nextPhase             Phase?                          @relation("WorkOrderNextPhase", fields: [nextPhaseId], references: [id])
  workflow              Workflow?                       @relation(fields: [workflowId], references: [id])
  woSerials             WoSerial[]
  sterilises            Sterilise[]
  batchHets             WorkOrderHet[]
  phaseEquips           WorkOrderPhaseEquip[]
  usedHets              Het[]                           @relation("HetUsedBy")
  finishedHets          Het[]                           @relation("HetFinishedBy")
  inventoryLots         InventoryLot[]
  inventoryConsumptions WorkOrderInventoryConsumption[]

  @@index([workflowId])
  @@index([tenantId])
  @@map("workOrder")
}

model WorkOrderHet {
  workOrderId String
  hetId       String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  het         Het       @relation(fields: [hetId], references: [id], onDelete: Cascade)

  @@id([workOrderId, hetId])
  @@map("workOrderHet")
}

model WorkOrderPhaseEquip {
  workOrderId  String
  phaseEquipId String
  workOrder    WorkOrder  @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  phaseEquip   PhaseEquip @relation(fields: [phaseEquipId], references: [id], onDelete: Cascade)

  @@id([workOrderId, phaseEquipId])
  @@map("workOrderPhaseEquip")
}

model WoSerial {
  id           String   @id
  tenantId     String   @default("ventas")
  createdOn    DateTime @default(now())
  createdById  String?
  updatedOn    DateTime @updatedAt
  updatedById  String?
  workOrderId  String
  bomRefId     String
  serialNumber String?
  keyText      String?

  createdBy Staff?    @relation("WoSerialCreatedBy", fields: [createdById], references: [id])
  updatedBy Staff?    @relation("WoSerialUpdatedBy", fields: [updatedById], references: [id])
  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
  bomRef    BomLine   @relation(fields: [bomRefId], references: [id])

  @@index([tenantId])
  @@map("woSerial")
}

model Sterilise {
  id            String    @id
  tenantId      String    @default("ventas")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdById   String?
  workOrderId   String
  manuId        String?
  direction     String?
  result        Boolean?
  betReading    Decimal?  @db.Decimal(18, 4)
  quantity      Int?
  comment       String?
  imagePath     String?
  signOn        DateTime?
  signById      String?
  signaturePath String?
  keyText       String?

  createdBy        Staff?         @relation("SteriliseCreatedBy", fields: [createdById], references: [id])
  updatedById      String?
  updatedBy        Staff?         @relation("SteriliseUpdatedBy", fields: [updatedById], references: [id])
  workOrder        WorkOrder      @relation(fields: [workOrderId], references: [id])
  manufacturer     Manufacturer?  @relation(fields: [manuId], references: [id])
  signBy           Staff?         @relation("SteriliseSignBy", fields: [signById], references: [id])
  batchHets        SteriliseHet[]
  currentWorkOrder WorkOrder?     @relation("WorkOrderSterilisationCurrent")

  @@index([tenantId])
  @@map("sterilise")
}

model SteriliseHet {
  steriliseId String
  hetId       String
  sterilise   Sterilise @relation(fields: [steriliseId], references: [id], onDelete: Cascade)
  het         Het       @relation(fields: [hetId], references: [id], onDelete: Cascade)

  @@id([steriliseId, hetId])
  @@map("steriliseHet")
}

model ManufacturerHet {
  manufacturerId String
  hetId          String
  manufacturer   Manufacturer @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)
  het            Het          @relation(fields: [hetId], references: [id], onDelete: Cascade)

  @@id([manufacturerId, hetId])
  @@map("manufacturerHet")
}

model SupplyEntity {
  id             String   @id
  tenantId       String
  name           String?
  legalName      String?
  externalCode   String?
  sourceSystem   String?
  legacyGroupKey String?
  legacyClinicId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
  @@index([legacyClinicId])
  @@map("supplyEntity")
}

model CollectionPoint {
  id             String   @id
  tenantId       String
  supplyEntityId String
  legacyClinicId String?
  hciCode        String?
  displayName    String?
  licenseName    String?
  address        String?
  postalCode     String?
  telephone      String?
  personInCharge String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
  @@index([supplyEntityId])
  @@index([legacyClinicId])
  @@map("collectionPoint")
}

model CollectionUnit {
  id                      String         @id
  tenantId                String
  supplyEntityId          String?
  collectionPointId       String?
  legacyHetId             String?
  unitNumber              String?
  parcelTrackingNumber    String?
  status                  String
  legacyDeliverId         String?
  legacyCollectId         String?
  legacyUsedByWorkOrderId String?
  legacyNextHetId         String?
  sourceSystem            String?
  linkCompleteness        String?
  semanticConfidence      String?
  hiddenFromOperations    Boolean        @default(false)
  deleted                 Boolean        @default(false)
  legacyRaw               Json?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  hets                    Het[]
  inventoryLots           InventoryLot[]

  @@index([tenantId])
  @@index([legacyHetId])
  @@index([collectionPointId])
  @@index([legacyUsedByWorkOrderId])
  @@index([status])
  @@map("collectionUnit")
}

model IssuanceOrder {
  id                     String    @id
  tenantId               String
  supplyEntityId         String?
  collectionPointId      String?
  issuedAt               DateTime?
  issuedBy               String?
  legacyDeliverCollectId String?
  legacyDirection        String?
  semanticConfidence     String?
  level                  String?
  remarks                String?
  legacyRaw              Json?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([tenantId])
  @@index([collectionPointId])
  @@index([legacyDeliverCollectId])
  @@map("issuanceOrder")
}

model IssuanceOrderLine {
  id                   String   @id @default(cuid())
  tenantId             String
  issuanceOrderId      String
  collectionUnitId     String?
  legacyHetId          String?
  legacyHetNumber      String?
  parcelTrackingNumber String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([issuanceOrderId, legacyHetId])
  @@index([tenantId])
  @@index([collectionUnitId])
  @@map("issuanceOrderLine")
}

model CollectionUnitFulfilment {
  id               String    @id @default(cuid())
  tenantId         String
  collectionUnitId String
  fulfilledAt      DateTime?
  fulfilledBy      String?
  source           String?
  evidencePath     String?
  remarks          String?
  inferred         Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([collectionUnitId, source])
  @@index([tenantId])
  @@map("collectionUnitFulfilment")
}

model CollectionOrder {
  id                            String    @id
  tenantId                      String
  supplyEntityId                String?
  collectionPointId             String?
  requestedAt                   DateTime?
  scheduledFor                  DateTime?
  requestedBy                   String?
  status                        String
  legacyCollectDeliverCollectId String?
  legacyDirection               String?
  semanticConfidence            String?
  legacyConflatedOrderReceipt   Boolean   @default(false)
  level                         String?
  remarks                       String?
  legacyRaw                     Json?
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  @@index([tenantId])
  @@index([collectionPointId])
  @@index([legacyCollectDeliverCollectId])
  @@map("collectionOrder")
}

model CollectionReceipt {
  id                            String    @id
  tenantId                      String
  collectionOrderId             String?
  receivedAt                    DateTime?
  receivedBy                    String?
  signaturePath                 String?
  remarks                       String?
  legacyCollectDeliverCollectId String?
  legacyConflatedOrderReceipt   Boolean   @default(false)
  acceptanceState               String?
  legacyRaw                     Json?
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  @@index([tenantId])
  @@index([collectionOrderId])
  @@index([legacyCollectDeliverCollectId])
  @@map("collectionReceipt")
}

model CollectionReceiptLine {
  id                  String   @id @default(cuid())
  tenantId            String
  collectionReceiptId String
  collectionUnitId    String?
  conditionStatus     String?
  acceptanceStatus    String?
  resultingHetId      String?
  discrepancyReason   String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  hets                Het[]

  @@unique([collectionReceiptId, collectionUnitId])
  @@index([tenantId])
  @@index([collectionUnitId])
  @@index([resultingHetId])
  @@map("collectionReceiptLine")
}

model InventoryReference {
  id           String   @id
  tenantId     String
  refType      String
  name         String
  shortCode    String?
  description  String?
  sourceSystem String?
  legacyRaw    Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, refType, name])
  @@index([tenantId])
  @@index([refType])
  @@map("inventoryReference")
}

model InventoryLocation {
  id               String   @id
  tenantId         String
  locationType     String
  name             String
  parentLocationId String?
  description      String?
  imagePath        String?
  sourceSystem     String?
  legacyRaw        Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  parentLocation   InventoryLocation?     @relation("InventoryLocationTree", fields: [parentLocationId], references: [id])
  childLocations   InventoryLocation[]    @relation("InventoryLocationTree")
  balances         InventoryBalance[]
  transactionsFrom InventoryTransaction[] @relation("InventoryTransactionFromLocation")
  transactionsTo   InventoryTransaction[] @relation("InventoryTransactionToLocation")
  lots             InventoryLot[]

  @@index([tenantId])
  @@index([locationType])
  @@index([parentLocationId])
  @@map("inventoryLocation")
}

model InventorySku {
  id             String   @id
  tenantId       String
  sku            String?
  description    String?
  category       String?
  brand          String?
  size           String?
  colour         String?
  uom            String?
  packQuantity   Decimal? @db.Decimal(18, 4)
  threshold      Decimal? @db.Decimal(18, 4)
  serialisedMode String?
  qrImagePath    String?
  mediaUrl       String?
  qrPrintPath    String?
  sourceSystem   String?
  legacyRaw      Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lots         InventoryLot[]
  balances     InventoryBalance[]
  transactions InventoryTransaction[]

  @@index([tenantId])
  @@index([sku])
  @@index([category])
  @@map("inventorySku")
}

model InventoryLot {
  id                 String   @id
  tenantId           String
  inventorySkuId     String?
  lotNumber          String?
  inventoryType      String
  status             String
  quantityInitial    Decimal? @db.Decimal(18, 4)
  quantityCurrent    Decimal? @db.Decimal(18, 4)
  uom                String?
  currentLocationId  String?
  collectionUnitId   String?
  hetId              String?  @unique
  workOrderId        String?
  sourceSystem       String?
  legacyItemSerialId String?
  legacyCheckInOutId String?
  legacyHetId        String?
  legacyRaw          Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  inventorySku    InventorySku?                   @relation(fields: [inventorySkuId], references: [id])
  currentLocation InventoryLocation?              @relation(fields: [currentLocationId], references: [id])
  collectionUnit  CollectionUnit?                 @relation(fields: [collectionUnitId], references: [id])
  het             Het?                            @relation("HetInventoryLot", fields: [hetId], references: [id])
  workOrder       WorkOrder?                      @relation(fields: [workOrderId], references: [id])
  balances        InventoryBalance[]
  transactions    InventoryTransaction[]
  parentGenealogy InventoryGenealogy[]            @relation("InventoryGenealogyParent")
  childGenealogy  InventoryGenealogy[]            @relation("InventoryGenealogyChild")
  consumptions    WorkOrderInventoryConsumption[]

  @@index([tenantId])
  @@index([inventorySkuId])
  @@index([collectionUnitId])
  @@index([currentLocationId])
  @@index([legacyItemSerialId])
  @@index([legacyHetId])
  @@index([inventoryType])
  @@index([status])
  @@map("inventoryLot")
}

model InventoryTransaction {
  id                 String    @id
  tenantId           String
  inventorySkuId     String?
  inventoryLotId     String?
  transactionType    String
  direction          String?
  reason             String?
  quantity           Decimal?  @db.Decimal(18, 4)
  uom                String?
  fromLocationId     String?
  toLocationId       String?
  workOrderId        String?
  occurredAt         DateTime?
  actor              String?
  signaturePath      String?
  remarks            String?
  legacyRefNumber    String?
  legacyRefNumberOut String?
  sourceSystem       String?
  legacyRaw          Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  inventorySku InventorySku?      @relation(fields: [inventorySkuId], references: [id])
  inventoryLot InventoryLot?      @relation(fields: [inventoryLotId], references: [id])
  fromLocation InventoryLocation? @relation("InventoryTransactionFromLocation", fields: [fromLocationId], references: [id])
  toLocation   InventoryLocation? @relation("InventoryTransactionToLocation", fields: [toLocationId], references: [id])

  @@index([tenantId])
  @@index([inventorySkuId])
  @@index([inventoryLotId])
  @@index([transactionType])
  @@index([occurredAt])
  @@index([legacyRefNumber])
  @@index([legacyRefNumberOut])
  @@map("inventoryTransaction")
}

model InventoryBalance {
  id                  String   @id
  tenantId            String
  inventorySkuId      String
  inventoryLotId      String?
  inventoryLocationId String?
  quantity            Decimal? @db.Decimal(18, 4)
  sourceSystem        String?
  legacyRaw           Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  inventorySku      InventorySku       @relation(fields: [inventorySkuId], references: [id])
  inventoryLot      InventoryLot?      @relation(fields: [inventoryLotId], references: [id])
  inventoryLocation InventoryLocation? @relation(fields: [inventoryLocationId], references: [id])

  @@unique([tenantId, inventorySkuId, inventoryLotId, inventoryLocationId])
  @@index([tenantId])
  @@index([inventorySkuId])
  @@index([inventoryLotId])
  @@index([inventoryLocationId])
  @@map("inventoryBalance")
}

model InventoryGenealogy {
  id                   String   @id @default(cuid())
  tenantId             String
  parentInventoryLotId String
  childInventoryLotId  String
  relationshipType     String
  workOrderId          String?
  phaseId              String?
  sourceSystem         String?
  legacyRaw            Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  parentInventoryLot InventoryLot @relation("InventoryGenealogyParent", fields: [parentInventoryLotId], references: [id])
  childInventoryLot  InventoryLot @relation("InventoryGenealogyChild", fields: [childInventoryLotId], references: [id])

  @@unique([parentInventoryLotId, childInventoryLotId, relationshipType])
  @@index([tenantId])
  @@index([parentInventoryLotId])
  @@index([childInventoryLotId])
  @@map("inventoryGenealogy")
}

model WorkOrderInventoryConsumption {
  id             String   @id @default(cuid())
  tenantId       String
  workOrderId    String
  inventoryLotId String?
  inventorySkuId String?
  bomLineId      String?
  quantity       Decimal? @db.Decimal(18, 4)
  uom            String?
  sourceSystem   String?
  legacyRaw      Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workOrder    WorkOrder     @relation(fields: [workOrderId], references: [id])
  inventoryLot InventoryLot? @relation(fields: [inventoryLotId], references: [id])

  @@index([tenantId])
  @@index([workOrderId])
  @@index([inventoryLotId])
  @@index([inventorySkuId])
  @@index([bomLineId])
  @@map("workOrderInventoryConsumption")
}

model InventoryImportReport {
  id         String    @id @default(cuid())
  tenantId   String
  source     String
  dryRun     Boolean   @default(false)
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  report     Json

  @@index([tenantId])
  @@map("inventoryImportReport")
}

model ProcurementImportReport {
  id         String    @id @default(cuid())
  tenantId   String
  source     String
  dryRun     Boolean   @default(false)
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  report     Json

  @@index([tenantId])
  @@map("procurementImportReport")
}

model PrintLabel {
  id             String    @id @default(cuid())
  tenantId       String    @default("ventas")
  path           String?
  fileUrl        String?
  createdTime    DateTime?
  lastModifiedBy String?
  mimeType       String?

  @@index([tenantId])
  @@map("printLabel")
}
