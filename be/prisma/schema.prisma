generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Placeholder schema — will be replaced by the full migration once seed data is inspected.
model Staff {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  bitrixId     String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("staff")
}
